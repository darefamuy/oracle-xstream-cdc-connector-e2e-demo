# =============================================================================
# AB Bank CDC Demo – Environment Variables
# Copy this to .env and adjust if needed. Defaults work for local laptop demo.
# =============================================================================

# ── Oracle ──────────────────────────────────────────────────────────────────
ORACLE_SYS_PASSWORD=Oracle21c!
ORACLE_CDB_NAME=XE
ORACLE_PDB_NAME=XEPDB1
ORACLE_PORT=1521

# XStream admin user (created in CDB)
XSTREAM_ADMIN_USER=c##ggadmin
XSTREAM_ADMIN_PASSWORD=Confluent12!

# Application schema
BANK_SCHEMA_USER=bankdb
BANK_SCHEMA_PASSWORD=BankDB2024!

# XStream outbound server name (must be uppercase)
XSTREAM_SERVER_NAME=XOUT
XSTREAM_CAPTURE_NAME=confluent_xout1

# ── Confluent Platform ───────────────────────────────────────────────────────
KAFKA_BROKER_PORT=9092
SCHEMA_REGISTRY_PORT=8081
CONNECT_PORT=8083
CONTROL_CENTER_PORT=9021

# Topic prefix matches PDB name
TOPIC_PREFIX=XEPDB1

# ── Connect Image ────────────────────────────────────────────────────────────
CONNECT_IMAGE_TAG=latest
CONFLUENT_PLATFORM_VERSION=7.9.0
